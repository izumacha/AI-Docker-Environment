#!/usr/bin/env bash
# aidock - wrapper for the Claude Code Docker sandbox.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." &>/dev/null && pwd)"

HOST_UID="$(id -u)"
HOST_GID="$(id -g)"
export HOST_UID HOST_GID

compose() {
    # compose.yaml requires HOST_WORKSPACE (no default) so that bypassing this
    # wrapper with a bare `docker compose run claude` fails closed instead of
    # mounting the repo. Subcommands that do not mount a user workspace
    # (build/logout/firewall-refresh) still need the variable to interpolate,
    # so supply a non-sensitive placeholder here. run/login/shell export the
    # guarded $PWD before calling compose, which takes precedence over this.
    HOST_WORKSPACE="${HOST_WORKSPACE:-/nonexistent}" \
        docker compose -f "${REPO_ROOT}/compose.yaml" "$@"
}

guard_workspace() {
    local pwd_abs home_abs passwd_home
    pwd_abs="$(realpath "$PWD")"

    # Anchor the guard base strictly to the passwd entry for the current
    # UID. Never fall back to the caller-supplied $HOME: a forged HOME (e.g.
    # HOME=/tmp) would relocate the comparison base and skip the SEC-8
    # sensitive-path checks. If the passwd home cannot be resolved to a real
    # directory, fail closed (exit 2) rather than trusting untrusted input.
    home_abs=""
    passwd_home="$(getent passwd "$(id -u)" 2>/dev/null | cut -d: -f6 || true)"
    if [[ -n "$passwd_home" && -d "$passwd_home" ]]; then
        home_abs="$(realpath "$passwd_home" 2>/dev/null || true)"
    fi
    if [[ -z "$home_abs" ]]; then
        echo "aidock: cannot resolve home directory from passwd database; refusing to proceed" >&2
        exit 2
    fi

    if [[ "$pwd_abs" == "/" ]]; then
        echo "aidock: refusing to mount / as /workspace" >&2
        exit 2
    fi
    if [[ "$pwd_abs" == "$home_abs" ]]; then
        echo "aidock: refusing to mount \$HOME as /workspace. cd into a project subdirectory first." >&2
        exit 2
    fi

    # Block known sensitive locations from being mounted into /workspace.
    local rel
    rel="${pwd_abs#"$home_abs"/}"
    case "$rel" in
        .ssh|.ssh/*|.aws|.aws/*|.gcloud|.gcloud/*|.config/gcloud|.config/gcloud/*|.azure|.azure/*|.config/azure|.config/azure/*|.config/aws|.config/aws/*|.config/git|.config/git/*|.config/gh|.config/gh/*|.kube|.kube/*|.docker|.docker/*)
            echo "aidock: refusing to mount sensitive directory under \$HOME: $pwd_abs" >&2
            exit 2
            ;;
        .gitconfig|.git-credentials|.netrc|.npmrc|.pypirc)
            echo "aidock: refusing to mount sensitive file under \$HOME: $pwd_abs" >&2
            exit 2
            ;;
    esac

    if [[ "$pwd_abs" == "/var/run/docker.sock" || "$pwd_abs" == "/var/run/docker.sock/"* ]]; then
        echo "aidock: refusing to mount docker socket path: $pwd_abs" >&2
        exit 2
    fi
}

cmd_build() {
    compose build "$@"
}

cmd_login() {
    guard_workspace
    export HOST_WORKSPACE="$PWD"
    export AIDOCK_PROFILE="login"
    compose run --rm claude claude /login
}

cmd_logout() {
    # `compose down -v` is the sole authoritative teardown: it removes the
    # project's claude-home volume, with Compose resolving the real,
    # project-scoped volume name automatically. Capture and propagate its exact
    # exit code and only claim success when it actually succeeded, so a failed
    # logout on a shared host is not silently reported as done with the
    # credential volume left behind (AC-5 / SEC-10 / FR-1.6).
    #
    # Do NOT reintroduce a hardcoded `docker volume rm aidock_claude-home`: the
    # real volume is <project>_claude-home (the project name defaults to the
    # lowercased directory name, e.g. ai-docker-environment_claude-home), so
    # that literal never matched here -- and worse, it could delete a same-named
    # global volume created by an unrelated project/checkout, a destructive
    # side effect (issue #9 / FR-1.6).
    local status=0
    compose down -v --remove-orphans || status=$?
    if (( status != 0 )); then
        echo "aidock: logout failed (compose down -v exited $status); credential volume may still exist (check 'docker volume ls')" >&2
        exit "$status"
    fi
    echo "aidock: credential volume removed"
}

cmd_run() {
    guard_workspace
    export HOST_WORKSPACE="$PWD"
    if [[ $# -gt 0 ]]; then
        compose run --rm claude "$@"
    else
        compose run --rm claude
    fi
}

cmd_shell() {
    guard_workspace
    export HOST_WORKSPACE="$PWD"
    compose run --rm claude bash
}

cmd_firewall_refresh() {
    # firewall-refresh re-resolves the DNS allowlist (e.g. after CDN IPs
    # rotate). `compose ps -q claude` can list more than one CID when several
    # claude containers run concurrently (e.g. `run` + `shell` in parallel);
    # every one of them needs the refresh. Collect the CIDs line-by-line into
    # an array (skipping blank lines) so each newline-separated CID stays a
    # distinct container ID instead of being concatenated into one invalid
    # argument to `docker exec`, then refresh each (FR-1.5).
    local cids=() cid status=0
    while IFS= read -r cid; do
        [[ -n "$cid" ]] && cids+=("$cid")
    done < <(compose ps -q claude)
    if [[ "${#cids[@]}" -eq 0 ]]; then
        echo "aidock: no running claude container" >&2
        exit 1
    fi
    # Refresh every container best-effort: a failure in one must not skip the
    # rest. Record the failure and propagate a non-zero exit at the end.
    for cid in "${cids[@]}"; do
        if ! docker exec -u root "$cid" /usr/local/bin/init-firewall.sh; then
            echo "aidock: firewall refresh failed for container $cid" >&2
            status=1
        fi
    done
    exit "$status"
}

usage() {
    cat <<'USAGE'
Usage: aidock <command> [args...]

Commands:
  build              Build the sandbox image with the current host UID/GID.
  login              Run `claude /login` once to seed OAuth credentials.
  run [args...]      Start Claude Code (default). Mounts $PWD as /workspace.
  shell              Open a bash shell inside the sandbox (debugging).
  firewall-refresh   Re-run the firewall init in every running claude
                     container (use after DNS-based IPs rotate).
  logout             Remove the persisted credential volume.
  help               Show this message.
USAGE
}

main() {
    local cmd="${1:-run}"
    [[ $# -gt 0 ]] && shift || true

    case "$cmd" in
        build)             cmd_build "$@";;
        login)             cmd_login "$@";;
        logout)            cmd_logout "$@";;
        run)               cmd_run "$@";;
        shell|bash)        cmd_shell "$@";;
        firewall-refresh)  cmd_firewall_refresh "$@";;
        help|-h|--help)    usage;;
        *)                 echo "aidock: unknown command '$cmd'" >&2; usage; exit 1;;
    esac
}

main "$@"
