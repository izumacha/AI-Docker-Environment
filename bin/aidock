#!/usr/bin/env bash
# aidock - wrapper for the Claude Code Docker sandbox.

# エラー発生時に即座に停止し、未定義変数の参照もエラーにする（安全なスクリプト実行の基本設定）
set -euo pipefail

# このスクリプト自身が置かれているディレクトリの絶対パスを取得する
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
# リポジトリのルートディレクトリ（SCRIPT_DIR の一つ上）を絶対パスで求める
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." &>/dev/null && pwd)"

# コンテナ内の agent ユーザーと同じ UID/GID をホストから取得する（ファイル所有権の一致のため）
HOST_UID="$(id -u)"
# 現在のユーザーのグループ ID を取得する
HOST_GID="$(id -g)"
# 子プロセス（docker compose）に UID/GID を環境変数として渡す
export HOST_UID HOST_GID

require_non_root_host() {
    # ホストが UID 0（root）だと、docker/Dockerfile が焼き込む agent ユーザーも UID 0 になる。
    # Linux の capability クリア規則は「実効 UID が 0 から非 0 へ変わったとき」だけ有効
    # capability を消去するため（capabilities(7)）、UID 0→0 の遷移では entrypoint.sh の
    # `gosu agent` 降格を経ても NET_ADMIN/NET_RAW（cap_add 済み）が実効 capability として
    # 残り続け、コンテナ内のワークロードが iptables/ip6tables を直接操作して egress
    # ファイアウォール（SEC-1/SEC-7 が前提とする「降格後の agent は capability を持たない」
    # という不変条件）を無効化できてしまう。
    if [[ "$HOST_UID" -eq 0 ]]; then
        echo "aidock: refusing to build/run as host UID 0 (root). The container's agent user would also become UID 0, and gosu's privilege drop does not clear inherited capabilities on a 0->0 transition, defeating the egress firewall's security model (SEC-18). Re-run as a non-root host user." >&2
        exit 2
    fi
    # ホストの GID が 0（root グループ）の場合も拒否する。こちらは capability クリアには
    # 影響しない（クリア規則は実効 UID のみを見る）が、agent のプライマリグループが
    # コンテナ内の root グループになり、group-root で読める既存ファイルへのアクセスが
    # 意図せず広がる余地が残るための多層防御。docker/Dockerfile 側でも HOST_GID=0 を
    # 明示的に拒否しており（bin/aidock を経由しない直接 docker build に対する二重の防御）、
    # ここでの拒否はそれと一致させて早期にわかりやすいエラーを出すためのもの。
    if [[ "$HOST_GID" -eq 0 ]]; then
        echo "aidock: refusing to build/run as host GID 0 (root group). The container's agent user would inherit a root primary group, widening its file-access surface inside the sandbox (SEC-18). Re-run as a non-root host user." >&2
        exit 2
    fi
}

compose() {
    # compose.yaml requires HOST_WORKSPACE (no default) so that bypassing this
    # wrapper with a bare `docker compose run claude` fails closed instead of
    # mounting the repo. Subcommands that do not mount a user workspace
    # (build/logout/firewall-refresh) still need the variable to interpolate,
    # so supply a non-sensitive placeholder here. run/login/shell export
    # guard_workspace()'s validated, resolved realpath before calling compose,
    # which takes precedence over this.
    # HOST_WORKSPACE が未設定のときは存在しないパス /nonexistent をプレースホルダとして使う
    HOST_WORKSPACE="${HOST_WORKSPACE:-/nonexistent}" \
        docker compose -f "${REPO_ROOT}/compose.yaml" "$@"
}

guard_workspace() {
    # $PWD の絶対パス（シンボリックリンクを解決済み）を取得する
    local pwd_abs home_abs passwd_home
    pwd_abs="$(realpath "$PWD")"

    # Anchor the guard base strictly to the passwd entry for the current
    # UID. Never fall back to the caller-supplied $HOME: a forged HOME (e.g.
    # HOME=/tmp) would relocate the comparison base and skip the SEC-8
    # sensitive-path checks. If the passwd home cannot be resolved to a real
    # directory, fail closed (exit 2) rather than trusting untrusted input.
    # ホームディレクトリの比較基準を空文字列で初期化する
    home_abs=""
    # /etc/passwd から現在ユーザーのホームディレクトリを取得する（$HOME は偽造できるため使わない）
    passwd_home="$(getent passwd "$(id -u)" 2>/dev/null | cut -d: -f6 || true)"
    # passwd で得たパスが実在するディレクトリであれば絶対パスに解決する
    if [[ -n "$passwd_home" && -d "$passwd_home" ]]; then
        home_abs="$(realpath "$passwd_home" 2>/dev/null || true)"
    fi
    # ホームディレクトリが解決できなかった場合は安全側に倒して終了する（fail-closed）
    if [[ -z "$home_abs" ]]; then
        echo "aidock: cannot resolve home directory from passwd database; refusing to proceed" >&2
        exit 2
    fi

    # / をそのままマウントしようとした場合は拒否する（SEC-8）
    if [[ "$pwd_abs" == "/" ]]; then
        echo "aidock: refusing to mount / as /workspace" >&2
        exit 2
    fi
    # $HOME そのものをマウントしようとした場合は拒否する（機密ファイルの流出防止）
    if [[ "$pwd_abs" == "$home_abs" ]]; then
        echo "aidock: refusing to mount \$HOME as /workspace. cd into a project subdirectory first." >&2
        exit 2
    fi
    # $HOME の祖先ディレクトリ（例: /home）をマウントしようとした場合も拒否する。
    # 祖先を許すと $HOME 自身がサブディレクトリとして /workspace 配下に現れてしまい、
    # 下の機密パスチェック（$HOME からの相対パス比較）を素通りして .ssh 等が露出する。
    if [[ "$home_abs" == "$pwd_abs"/* ]]; then
        echo "aidock: refusing to mount an ancestor of \$HOME as /workspace (would expose \$HOME as a subdirectory): $pwd_abs" >&2
        exit 2
    fi

    # Block known sensitive locations from being mounted into /workspace.
    # $HOME 以下の相対パスを求めて既知の機密ディレクトリ・ファイルに一致するか確認する
    local rel
    rel="${pwd_abs#"$home_abs"/}"
    # SSH 鍵・AWS 設定・GCP 設定・Azure 設定・Kubernetes 設定・Docker 設定・GPG 鍵などの機密パスを拒否する
    # 注: `.config` は「完全一致のみ」拒否する（`.config/*` は付けない）。親を丸ごとマウントすると
    #     配下の .config/aws / .config/gcloud / .config/azure / .config/git / .config/gh が一括露出
    #     するため親自体は拒否しつつ、.config/htop 等の非機密サブディレクトリからの起動は許可を維持する（SEC-8）
    case "$rel" in
        .ssh|.ssh/*|.aws|.aws/*|.gcloud|.gcloud/*|.config|.config/gcloud|.config/gcloud/*|.azure|.azure/*|.config/azure|.config/azure/*|.config/aws|.config/aws/*|.config/git|.config/git/*|.config/gh|.config/gh/*|.config/op|.config/op/*|.config/doctl|.config/doctl/*|.config/rclone|.config/rclone/*|.config/hub|.config/hub/*|.kube|.kube/*|.docker|.docker/*|.gnupg|.gnupg/*|.terraform.d|.terraform.d/*|.cargo|.cargo/*|.m2|.m2/*|.gem|.gem/*)
            echo "aidock: refusing to mount sensitive directory under \$HOME: $pwd_abs" >&2
            exit 2
            ;;
        # 認証情報ファイル（.gitconfig / .netrc / .npmrc / .pgpass / .vault-token / .terraformrc 等）もマウント拒否する
        # .terraformrc は .terraform.d/credentials.tfrc.json と同じ Terraform Cloud/Enterprise API
        # トークンを保持しうる CLI 設定ファイル（$HOME 直下に置かれる旧来形式）で、
        # 既存の .terraform.d ディレクトリ拒否だけではこのファイル単体は防げないため追加する
        .gitconfig|.git-credentials|.netrc|.npmrc|.pypirc|.pgpass|.vault-token|.terraformrc)
            echo "aidock: refusing to mount sensitive file under \$HOME: $pwd_abs" >&2
            exit 2
            ;;
    esac

    # Docker ソケットのパスをワークスペースとしてマウントしようとした場合も拒否する
    if [[ "$pwd_abs" == "/var/run/docker.sock" || "$pwd_abs" == "/var/run/docker.sock/"* ]]; then
        echo "aidock: refusing to mount docker socket path: $pwd_abs" >&2
        exit 2
    fi

    # 検証済みの実パス（シンボリックリンク解決済み）を呼び出し元へ返す。
    # 呼び出し元はこの値をそのまま HOST_WORKSPACE に使うこと。生の $PWD を
    # 再利用すると、ここでの検証後・docker compose run 実行までの間に
    # symlink の向き先が差し替えられた場合、検証したパスとは別の場所が
    # bind mount されてしまう（TOCTOU）。検証済みの実パスをそのまま使うことで、
    # symlink の以降の付け替えが mount 先に影響しなくなる。
    printf '%s\n' "$pwd_abs"
}

cmd_build() {
    # ホストが root だとイメージに焼き込まれる agent の UID/GID も root になるため先に拒否する
    require_non_root_host
    # Docker イメージをビルドする（HOST_UID/HOST_GID は compose() 経由で渡る）
    compose build "$@"
}

cmd_login() {
    # ホストが root だと gosu 降格後も capability が残りうるため先に拒否する（SEC-18）
    require_non_root_host
    # ワークスペースが安全かチェックし、検証済みの実パス（symlink 解決済み）を受け取る
    local resolved_workspace
    resolved_workspace="$(guard_workspace)"
    # 検証したのと同じ実パスをコンテナの /workspace としてマウントするよう設定する（TOCTOU 回避）
    export HOST_WORKSPACE="$resolved_workspace"
    # ログインプロファイルを設定する（ファイアウォールが OAuth 用ホストへのアクセスを許可する）
    export AIDOCK_PROFILE="login"
    # コンテナ内で `claude /login` を実行して OAuth 認証情報を初期化する
    compose run --rm claude claude /login
}

cmd_logout() {
    # `compose down -v` is the sole authoritative teardown: it removes the
    # project's claude-home volume, with Compose resolving the real,
    # project-scoped volume name automatically. Capture and propagate its exact
    # exit code and only claim success when it actually succeeded, so a failed
    # logout on a shared host is not silently reported as done with the
    # credential volume left behind (AC-5 / SEC-10 / FR-1.6).
    #
    # Do NOT reintroduce a hardcoded `docker volume rm aidock_claude-home`: the
    # real volume is <project>_claude-home (the project name defaults to the
    # lowercased directory name, e.g. ai-docker-environment_claude-home), so
    # that literal never matched here -- and worse, it could delete a same-named
    # global volume created by an unrelated project/checkout, a destructive
    # side effect (issue #9 / FR-1.6).
    # ログアウト処理の終了コードを保持する変数（0 = 成功）
    local status=0
    # コンテナを停止しボリューム（認証情報）を削除する。失敗しても exit しないで終了コードを記録する
    compose down -v --remove-orphans || status=$?
    # ログアウトが失敗した場合はエラーメッセージを出力して同じ終了コードで終了する
    if (( status != 0 )); then
        echo "aidock: logout failed (compose down -v exited $status); credential volume may still exist (check 'docker volume ls')" >&2
        exit "$status"
    fi
    # 正常にログアウトできたことをユーザーに知らせる（他の aidock: メッセージと同様に stderr へ出力し、
    # CLAUDE.md §6 の Bash 規約「ログは stderr」との一貫性を保つ）
    echo "aidock: credential volume removed" >&2
}

cmd_run() {
    # ホストが root だと gosu 降格後も capability が残りうるため先に拒否する（SEC-18）
    require_non_root_host
    # ワークスペースが安全かチェックし、検証済みの実パス（symlink 解決済み）を受け取る
    local resolved_workspace
    resolved_workspace="$(guard_workspace)"
    # 検証したのと同じ実パスをコンテナの /workspace にマウントするよう設定する（TOCTOU 回避）
    export HOST_WORKSPACE="$resolved_workspace"
    # 通常起動用の「run」プロファイルを明示的に固定する（SEC-19）。ここで固定しないと、
    # 呼び出し元シェルにたまたま AIDOCK_PROFILE=login が残っていた場合（例: 直前の
    # `aidock login` 用に手動 export したまま unset し忘れた等）、compose.yaml の
    # `${AIDOCK_PROFILE:-run}` 補間がホストの環境変数をそのまま引き継ぎ、通常セッション
    # なのに OAuth 用ホスト（claude.ai 等）への許可リストが無言で広がってしまう。
    export AIDOCK_PROFILE="run"
    # 追加引数がある場合はそれをコンテナに渡し、なければデフォルトコマンド（claude）を実行する
    if [[ $# -gt 0 ]]; then
        compose run --rm claude "$@"
    else
        compose run --rm claude
    fi
}

cmd_shell() {
    # ホストが root だと gosu 降格後も capability が残りうるため先に拒否する（SEC-18）
    require_non_root_host
    # ワークスペースが安全かチェックし、検証済みの実パス（symlink 解決済み）を受け取る
    local resolved_workspace
    resolved_workspace="$(guard_workspace)"
    # 検証したのと同じ実パスをコンテナの /workspace にマウントするよう設定する（TOCTOU 回避）
    export HOST_WORKSPACE="$resolved_workspace"
    # 通常起動用の「run」プロファイルを明示的に固定する（SEC-19、cmd_run() と同じ理由）
    export AIDOCK_PROFILE="run"
    # コンテナ内で bash シェルを起動する（デバッグ・調査用）
    compose run --rm claude bash
}

cmd_firewall_refresh() {
    # firewall-refresh re-resolves the DNS allowlist (e.g. after CDN IPs
    # rotate). aidock only ever creates containers via `compose run --rm`
    # (run/login/shell), and plain `compose ps` excludes those one-off
    # containers by default -- without `--all` the refresh would never find
    # any container. `--filter status=running` then narrows the list back to
    # live containers only. Several claude containers can run concurrently
    # (e.g. `run` + `shell` in parallel); every one of them needs the refresh.
    # Collect the CIDs line-by-line into an array (skipping blank lines) so
    # each newline-separated CID stays a distinct container ID instead of
    # being concatenated into one invalid argument to `docker exec`, then
    # refresh each (FR-1.5).
    # 実行中コンテナ ID の配列と現在処理中の ID、全体の終了ステータスを初期化する
    local cids=() cid status=0 ps_output
    # compose ps の出力を一旦変数へ読み込み、コマンド自体の終了コードを確認する。
    # プロセス置換 `< <(...)` に直接つなぐと終了コードを調べられず、compose ps 自体の
    # 失敗（例: Docker デーモン停止、compose プロジェクト解決失敗）が黙って
    # 空のコンテナ一覧として扱われ、後段の「no running claude container」という
    # 実際の原因とは無関係な一次診断メッセージになってしまう（アンダーコメント参照）。
    if ! ps_output=$(compose ps -q --all --filter status=running claude); then
        # compose ps 自体が失敗した場合は原因の切り分けを促すメッセージを出して終了する
        echo "aidock: failed to list containers (is the Docker daemon running?)" >&2
        exit 1
    fi
    # 実行中の claude コンテナの ID を 1 行ずつ読み込んで配列に格納する
    # （--all: compose run 由来の one-off コンテナも含める / --filter: 稼働中のみに絞る）
    while IFS= read -r cid; do
        # 空行はスキップして有効な CID だけを配列に追加する
        [[ -n "$cid" ]] && cids+=("$cid")
    done <<< "$ps_output"
    # 実行中のコンテナが 1 つもなければエラーを出力して終了する
    if [[ "${#cids[@]}" -eq 0 ]]; then
        echo "aidock: no running claude container" >&2
        exit 1
    fi
    # Refresh every container best-effort: a failure in one must not skip the
    # rest. Record the failure and propagate a non-zero exit at the end.
    # コンテナごとにファイアウォールを再初期化する（1 つ失敗しても残りを継続する）
    for cid in "${cids[@]}"; do
        # root 権限でコンテナ内の init-firewall.sh を再実行して DNS 許可リストを更新する
        if ! docker exec -u root "$cid" /usr/local/bin/init-firewall.sh; then
            # 失敗した場合はエラーメッセージを記録して終了ステータスに 1 をセットする
            echo "aidock: firewall refresh failed for container $cid" >&2
            status=1
        fi
    done
    # 全コンテナの処理が終わったら最終的な終了ステータスで終了する
    exit "$status"
}

usage() {
    # 使い方メッセージをヒアドキュメントで標準出力に出力する
    cat <<'USAGE'
Usage: aidock <command> [args...]

Commands:
  build              Build the sandbox image with the current host UID/GID.
  login              Run `claude /login` once to seed OAuth credentials.
  run [args...]      Start Claude Code (default). Mounts $PWD as /workspace.
  shell              Open a bash shell inside the sandbox (debugging).
  firewall-refresh   Re-run the firewall init in every running claude
                     container (use after DNS-based IPs rotate).
  logout             Remove the persisted credential volume.
  help               Show this message.
USAGE
}

main() {
    # 第一引数をコマンド名として受け取る。引数がなければ既定値 "run" を使う
    local cmd="${1:-run}"
    # 第一引数を消費して残りの引数だけを "$@" に残す（引数がない場合は何もしない）。
    # `[[ ... ]] && shift || true` という書き方は shellcheck SC2015（A && B || C は
    # if-then-else ではない）を誘発するため、意図が一目で分かる if 文に置き換える
    # （挙動は変えず、shift するかどうかの分岐のみを明確化する）
    if [[ $# -gt 0 ]]; then
        shift
    fi

    # コマンド名に応じて対応する関数を呼び出す
    case "$cmd" in
        build)             cmd_build "$@";;
        login)             cmd_login "$@";;
        logout)            cmd_logout "$@";;
        run)               cmd_run "$@";;
        # shell と bash は同じ関数にマッピングする
        shell|bash)        cmd_shell "$@";;
        firewall-refresh)  cmd_firewall_refresh "$@";;
        # ヘルプオプションはいずれも使い方を表示する
        help|-h|--help)    usage;;
        # 未知のコマンドはエラーを出力して終了コード 1 で終わる
        *)                 echo "aidock: unknown command '$cmd'" >&2; usage; exit 1;;
    esac
}

# スクリプトへの全引数を main 関数に渡して処理を開始する
main "$@"
